# Keep text files checked out with LF on every platform.
* text=auto eol=lf

# Windows command scripts conventionally use CRLF.
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary assets must not be line-ending normalized.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.icns binary
*.pdf binary
*.sqlite binary
*.db binary
