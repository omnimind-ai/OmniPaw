{
  "name": "openomniclaw-electron",
  "version": "1.0.0",
  "description": "OpenOmniClaw desktop client built with Electron.",
  "type": "module",
  "main": "out/main/main.cjs",
  "scripts": {
    "rebuild:electron": "electron-builder install-app-deps",
    "predev": "pnpm rebuild:electron",
    "dev": "node scripts/electron-vite.mjs",
    "start": "node scripts/electron-vite.mjs preview",
    "build": "vue-tsc --noEmit && electron-vite build",
    "typecheck": "vue-tsc --noEmit",
    "db:smoke": "tsx scripts/db-smoke.ts",
    "chat-core:smoke": "tsx scripts/chat-core-smoke.ts",
    "pack": "pnpm rebuild:electron && pnpm build && electron-builder --dir",
    "dist": "pnpm rebuild:electron && pnpm build && electron-builder",
    "lint": "vue-tsc --noEmit"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.32.0",
  "dependencies": {
    "@mdi/font": "^7.4.47",
    "@vitejs/plugin-vue": "^6.0.3",
    "axios": "^1.16.1",
    "axios-mock-adapter": "^2.1.0",
    "better-sqlite3": "^12.10.0",
    "dompurify": "^3.4.3",
    "electron-vite": "^5.0.0",
    "event-source-polyfill": "^1.0.31",
    "katex": "^0.16.46",
    "markdown-it": "^14.1.1",
    "markstream-vue": "0.0.6",
    "mermaid": "^11.15.0",
    "pinia": "^3.0.4",
    "sass": "^1.99.0",
    "shiki": "^3.20.0",
    "vite-plugin-vuetify": "^2.1.3",
    "vue": "^3.5.26",
    "vue-router": "^4.6.3",
    "vuetify": "^3.7.11"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.7.0",
    "electron": "^36.8.1",
    "electron-builder": "^26.8.1",
    "playwright": "^1.60.0",
    "tsx": "^4.22.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.3",
    "vue-tsc": "^3.1.8"
  },
  "build": {
    "appId": "com.openomniclaw.desktop",
    "productName": "OpenOmniClaw",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "resources/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "**/*.node"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
