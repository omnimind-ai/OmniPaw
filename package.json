{
  "name": "openomniclaw-electron",
  "version": "1.0.0",
  "description": "OpenOmniClaw desktop client built with Electron.",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "lint": "node --check src/main/main.js && node --check src/preload/preload.js && node --check src/renderer/app.js && node --check src/renderer/cat-window.js && node --check src/renderer/cat-panel.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.32.0",
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.7.0",
    "electron": "^42.0.1",
    "electron-builder": "^26.8.1",
    "playwright": "^1.60.0"
  },
  "build": {
    "appId": "com.openomniclaw.desktop",
    "productName": "OpenOmniClaw",
    "directories": {
      "output": "release"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
